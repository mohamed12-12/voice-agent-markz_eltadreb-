GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_USE_VERTEXAI=false
GEMINI_VOICE=Orus
GEMINI_LANGUAGE=ar-EG
GEMINI_TEMPERATURE=0.45
GEMINI_MAX_OUTPUT_TOKENS=520
GEMINI_TOP_P=0.8
GEMINI_VAD_SILENCE_MS=2600
GEMINI_VAD_PREFIX_PADDING_MS=1000
GEMINI_START_OF_SPEECH_SENSITIVITY=high
GEMINI_END_OF_SPEECH_SENSITIVITY=low
MIN_ENDPOINTING_DELAY=1.6
MAX_ENDPOINTING_DELAY=3.4
ALLOW_INTERRUPTIONS=true
MIN_INTERRUPTION_DURATION=1.2
MIN_INTERRUPTION_WORDS=1
RESUME_FALSE_INTERRUPTION=true
FALSE_INTERRUPTION_TIMEOUT=3.2
PREEMPTIVE_GENERATION=false
MIN_CONSECUTIVE_SPEECH_DELAY=0.45
USER_AWAY_TIMEOUT=12.0
AEC_WARMUP_DURATION=1.5

LIVEKIT_URL=your_livekit_url_here
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
AGENT_NAME=carim-agent

# Google Sheets Configuration
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=Leads
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
